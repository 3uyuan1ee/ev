@article{BAEK2026100512,
title = {Total cost of ownership of vehicle electrification and fuel switching options for light-duty and heavy-duty vehicles},
journal = {eTransportation},
volume = {27},
pages = {100512},
year = {2026},
issn = {2590-1168},
doi = {https://doi.org/10.1016/j.etran.2025.100512},
url = {https://www.sciencedirect.com/science/article/pii/S2590116825001195},
author = {Kwang Hoon Baek and Xinyi Wu and Yan Zhou and Ram Vijayagopal and Namdoo Kim and Amgad Elgowainy},
keywords = {Vehicle electrification, Total cost of ownership, Battery electric vehicle, Fuel cell electric vehicle},
abstract = {Projecting the transition from combustion engines to battery-based powertrains is complex becuase it involves numerous interdependent decisions. This study estimates total cost of ownership (TCO) to assess the economic viability of powertrain electrification, focusing exclusively on advances in vehicle and fuel technologies. Under two bounding technology-progress scenarios, we develop vehicle designs and fuel cost trajectories, which serve as inputs to TCO projections for selected classes from 2021 to 2050. We analyzed a small sport utility vehicle (SUV) to represent the light-duty vehicle (LDV) sector, and four medium- and heavy-duty vehicle (MHDV) classes: Class 6 box delivery, Class 8 drayage, Class 8 long-haul, and Class 8 transit bus. For each class, we compared the TCO of battery electric vehicles (BEVs) and fuel cell hybrid electric vehicles (FCHEVs) against conventional internal combustion engine vehicles (ICEVs). The results show that modern ICEVs generally have lower TCO; however, BEVs and FCHEVs could match or have lower TCOs than ICEVs over time, depending on technological progress. In LDVs, BEV300 is projected to deliver the lowest TCO by 2050, particularly under the high-progress scenario. In MHDVs, both BEVs and FCHEVs could become more cost-competitive than ICEVs by 2050 in the high-progress case. Beyond these results, the findings suggest further investigation is warranted for BEV charging infrastructure, FCHEV hydrogen refueling infrastructure, and MHDV charging strategies. These factors could reduce the fuel-cost share of TCO and enhance the competitiveness of BEVs and FCHEVs relative to ICEVs.}
}